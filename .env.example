# Copy this file to .env.local and fill in the values below.
# .env.local is gitignored - never commit real keys.

# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Spoonacular API key (spoonacular.com/food-api -> Profile -> API Keys)
SPOONACULAR_API_KEY=

# Random secret string - used to protect the /api/cron/refresh-cache route.
# Set the same value here and in Vercel's environment variables.
CRON_SECRET=
